{
  "appId": "com.perso-todo.app",
  "productName": "perso-todo",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "src/main/**/*",
    "assets/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/tray-icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerLanguages": ["ko"]
  },
  "extraMetadata": {
    "main": "src/main/index.js"
  }
}
